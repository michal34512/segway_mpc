{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(J-Link) Build & Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "jlink",
            "device": "${config:stm32.device}",
            "interface": "swd",
            "serialNumber": "",
            "executable": "${config:stm32.buildFolder}/Debug/${config:stm32.projectName}.elf",
            "loadFiles": [
                "${config:stm32.buildFolder}/Debug/${config:stm32.projectName}.elf"
            ],
            "cwd": "${workspaceFolder}",
            "runToEntryPoint": "main",
            "serverpath": "${config:stm32.jlinkPath}",
            "svdFile": "${config:stm32.svdPath}",
            "armToolchainPath": "${config:stm32.armToolchainPath}",
            "gdbPath": "${config:stm32.gdbPath}",
            "rtos": "FreeRTOS",
            "showDevDebugOutput": "both",
            "preLaunchTask": "CMake: Build Debug",
            "serverArgs": [
                "-verbose"
            ],
        },
        {
            "name": "(J-Link) Attach",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "jlink",
            "device": "${config:stm32.device}",
            "interface": "swd",
            "serialNumber": "",
            "executable": "${config:stm32.buildFolder}/Debug/${config:stm32.projectName}.elf",
            "cwd": "${workspaceFolder}",
            "serverpath": "${config:stm32.jlinkPath}",
            "svdFile": "${config:stm32.svdPath}",
            "armToolchainPath": "${config:stm32.armToolchainPath}",
            "gdbPath": "${config:stm32.gdbPath}",
            "rtos": "FreeRTOS",
            "showDevDebugOutput": "raw",
        },
        {
            "name": "(ST-Link) Build & Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "stlink",
            "device": "${config:stm32.device}",
            "interface": "swd",
            "serialNumber": "",
            "executable": "${config:stm32.buildFolder}/Debug/${config:stm32.projectName}.elf",
            "loadFiles": [
                "${config:stm32.buildFolder}/Debug/${config:stm32.projectName}.elf"
            ],
            "cwd": "${workspaceFolder}",
            "runToEntryPoint": "main",
            "svdFile": "${config:stm32.svdPath}",
            "armToolchainPath": "${config:stm32.armToolchainPath}",
            "gdbPath": "${config:stm32.gdbPath}",
            "showDevDebugOutput": "raw",
            "preLaunchTask": "CMake: Build Debug"
        },
        {
            "name": "(ST-Link) Attach",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "stlink",
            "device": "${config:stm32.device}",
            "interface": "swd",
            "serialNumber": "",
            "executable": "${config:stm32.buildFolder}/Debug/${config:stm32.projectName}.elf",
            "cwd": "${workspaceFolder}",
            "svdFile": "${config:stm32.svdPath}",
            "armToolchainPath": "${config:stm32.armToolchainPath}",
            "gdbPath": "${config:stm32.gdbPath}",
            "showDevDebugOutput": "raw",
        },
    ]
}